# ─────────────────────────────────────────────────
#  Launch House Sales Dashboard — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to Git. It is in .gitignore.
# ─────────────────────────────────────────────────

# ── HUBSPOT ──────────────────────────────────────
# Create a Private App in HubSpot:
#   Settings → Integrations → Private Apps → Create
#   Required scopes: crm.objects.tasks.read, crm.objects.tasks.write,
#                    crm.objects.deals.read, crm.objects.deals.write,
#                    crm.objects.contacts.read
HUBSPOT_ACCESS_TOKEN=pat-na1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── GOOGLE CALENDAR ───────────────────────────────
# Service Account (for Thomas's calendar only — simple setup)
# OR OAuth credentials (for multi-user — Cam + Todd get their own view)
#
# Option A — Service Account (recommended to start):
#   GCP Console → IAM → Service Accounts → Create → Download JSON
#   Share Thomas's calendar with the service account email
GOOGLE_SERVICE_ACCOUNT_EMAIL=sales-dashboard@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
THOMAS_CALENDAR_ID=thomas@launchhouse.golf

# ── SUPABASE ──────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Public anon key (safe to expose in frontend)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── SECURITY ──────────────────────────────────────
# A random secret to protect your API endpoints.
# Generate with: openssl rand -hex 32
API_SECRET=your-random-secret-here

# ── APP ───────────────────────────────────────────
# The URL where your dashboard is hosted
APP_URL=https://sales.launchhouse.golf
